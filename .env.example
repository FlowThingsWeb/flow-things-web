# ============================================
# SUPABASE
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================
# MERCADO PAGO
# ============================================
# PRODUCCIÓN: usar el Access Token de la app PRODUCTIVA (empieza con APP_USR-).
# El checkout usa Checkout Pro (redirect init_point), por lo que la Public Key
# NO se usa en el frontend — solo importa el Access Token.
MP_ACCESS_TOKEN=APP_USR-...
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-...        # (no usado actualmente — Checkout Pro por redirect)

# Firma del webhook. Copiar el "secret" que da el panel de MP al configurar la
# notificación (Webhooks). Con esto se valida x-signature (HMAC-SHA256).
MP_WEBHOOK_SECRET=...
# Poner en 'true' UNA VEZ confirmado que el secret es correcto: rechaza toda
# notificación con firma inválida (recomendado en producción).
MP_WEBHOOK_STRICT=true

# ============================================
# CRON / JOBS (fulfillment: factura, email, stock)
# ============================================
# Protege /api/cron/procesar-jobs. Vercel lo manda como Authorization: Bearer.
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=...

# ============================================
# AFIP (facturación electrónica — WSFE producción)
# ============================================
# Certificado y clave privada de PRODUCCIÓN (no homologación), en base64 o PEM.
AFIP_CERT=...
AFIP_KEY=...
AFIP_CUIT=20xxxxxxxx9
AFIP_PTO_VENTA=5
# Kill-switch: 'false' desactiva la emisión de factura (se cobra igual).
# Dejar sin setear o en 'true' para emitir facturas reales.
AFIP_HABILITADO=true

# ============================================
# EMAIL (Gmail SMTP)
# ============================================
GMAIL_USER=ventas@flowthings.com.ar
# App Password de Gmail (no la contraseña normal): https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# ============================================
# NOTIFICACIONES AL NEGOCIO (Telegram — opcional)
# ============================================
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# ============================================
# ADMIN AUTH (JWT)
# ============================================
ADMIN_EMAIL=admin@flowthings.com.ar
ADMIN_PASSWORD=CambiaEstePassword123!
ADMIN_SECRET=genera_esto_con_node_-e_"console.log(require('crypto').randomBytes(64).toString('hex'))"

# ============================================
# CABIFY LOGISTICS (opcional — el cálculo de envío usa tarifas por zona de la
# config; Cabify no es requerido para operar)
# ============================================
CABIFY_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CABIFY_CLIENT_SECRET=your_cabify_secret_here

# ============================================
# APP
# ============================================
# Dominio real de producción. Se usa para back_urls y notification_url de MP.
NEXT_PUBLIC_APP_URL=https://flowthings.com.ar

# ============================================
# ANALYTICS (opcional — se activan solo si están seteadas)
# ============================================
# Google Analytics 4 (formato G-XXXXXXX)
NEXT_PUBLIC_GA_ID=
# Meta (Facebook/Instagram) Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=

# ============================================
# CUPÓN POST-COMPRA (opcional)
# ============================================
# Código que se muestra en /exito para la próxima compra. Creá ese código en
# /admin/descuentos para que sea válido. Si queda vacío, no se muestra.
NEXT_PUBLIC_CUPON_POSTCOMPRA=
